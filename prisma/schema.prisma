generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id            Int           @id @default(autoincrement())
  nama          String
  slug          String        @unique
  email         String?
  telepon       String?
  alamat        String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  akun          Akun[]
  barang        Barang[]
  jurnalEntries JurnalEntry[]
  kategori      Kategori[]
  pelanggan     Pelanggan[]
  pengadaan     Pengadaan[]
  penjualan     Penjualan[]
  supplier      Supplier[]
  users         User[]
}

model User {
  id            Int           @id @default(autoincrement())
  name          String
  email         String        @unique
  password      String
  role          Role          @default(STAFF)
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  companyId     Int
  jurnalEntries JurnalEntry[]
  pengadaan     Pengadaan[]
  penjualan     Penjualan[]
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Kategori {
  id        Int      @id @default(autoincrement())
  nama      String
  companyId Int
  barang    Barang[]
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, nama])
}

model Supplier {
  id        Int         @id @default(autoincrement())
  nama      String
  alamat    String?
  telepon   String?
  email     String?
  companyId Int
  pengadaan Pengadaan[]
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Pelanggan {
  id        Int         @id @default(autoincrement())
  nama      String
  alamat    String?
  telepon   String?
  companyId Int
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  penjualan Penjualan[]

  @@index([companyId])
}

model Barang {
  id              Int               @id @default(autoincrement())
  kode            String
  nama            String
  kategoriId      Int?
  satuan          String            @default("pcs")
  hargaBeli       Decimal           @db.Decimal(15, 2)
  hargaJual       Decimal           @db.Decimal(15, 2)
  stok            Int               @default(0)
  stokMinimum     Int               @default(5)
  deskripsi       String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  companyId       Int
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kategori        Kategori?         @relation(fields: [kategoriId], references: [id])
  pengadaanDetail PengadaanDetail[]
  penjualanDetail PenjualanDetail[]

  @@unique([companyId, kode])
  @@index([kategoriId])
}

model Pengadaan {
  id            Int               @id @default(autoincrement())
  nomor         String
  tanggal       DateTime          @default(now())
  supplierId    Int?
  userId        Int
  status        String            @default("SELESAI")
  catatan       String?
  total         Decimal           @default(0.00) @db.Decimal(15, 2)
  createdAt     DateTime          @default(now())
  companyId     Int
  diskonNominal Decimal           @default(0.00) @db.Decimal(15, 2)
  diskonPersen  Decimal           @default(0.00) @db.Decimal(5, 2)
  ppn           Decimal           @default(0.00) @db.Decimal(15, 2)
  subtotal      Decimal           @default(0.00) @db.Decimal(15, 2)
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier      Supplier?         @relation(fields: [supplierId], references: [id])
  user          User              @relation(fields: [userId], references: [id])
  detail        PengadaanDetail[]

  @@unique([companyId, nomor])
  @@index([supplierId])
  @@index([userId])
}

model PengadaanDetail {
  id          Int       @id @default(autoincrement())
  pengadaanId Int
  barangId    Int
  qty         Int
  hargaSatuan Decimal   @db.Decimal(15, 2)
  subtotal    Decimal   @db.Decimal(15, 2)
  barang      Barang    @relation(fields: [barangId], references: [id])
  pengadaan   Pengadaan @relation(fields: [pengadaanId], references: [id], onDelete: Cascade)

  @@index([pengadaanId])
  @@index([barangId])
}

model Penjualan {
  id            Int               @id @default(autoincrement())
  nomor         String
  tanggal       DateTime          @default(now())
  pelangganId   Int?
  userId        Int
  status        String            @default("SELESAI")
  catatan       String?
  total         Decimal           @default(0.00) @db.Decimal(15, 2)
  createdAt     DateTime          @default(now())
  companyId     Int
  diskonNominal Decimal           @default(0.00) @db.Decimal(15, 2)
  diskonPersen  Decimal           @default(0.00) @db.Decimal(5, 2)
  ppn           Decimal           @default(0.00) @db.Decimal(15, 2)
  subtotal      Decimal           @default(0.00) @db.Decimal(15, 2)
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pelanggan     Pelanggan?        @relation(fields: [pelangganId], references: [id])
  user          User              @relation(fields: [userId], references: [id])
  detail        PenjualanDetail[]

  @@unique([companyId, nomor])
  @@index([pelangganId])
  @@index([userId])
}

model PenjualanDetail {
  id          Int       @id @default(autoincrement())
  penjualanId Int
  barangId    Int
  qty         Int
  hargaSatuan Decimal   @db.Decimal(15, 2)
  subtotal    Decimal   @db.Decimal(15, 2)
  barang      Barang    @relation(fields: [barangId], references: [id])
  penjualan   Penjualan @relation(fields: [penjualanId], references: [id], onDelete: Cascade)

  @@index([penjualanId])
  @@index([barangId])
}

model Akun {
  id           Int            @id @default(autoincrement())
  kode         String
  nama         String
  tipe         TipeAkun
  saldoNormal  SaldoNormal
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  companyId    Int
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jurnalDetail JurnalDetail[]

  @@unique([companyId, kode])
  @@index([tipe])
}

model JurnalEntry {
  id            Int            @id @default(autoincrement())
  nomor         String
  tanggal       DateTime       @default(now())
  keterangan    String?
  referensiTipe String         @default("manual")
  referensiId   Int?
  userId        Int
  createdAt     DateTime       @default(now())
  companyId     Int
  detail        JurnalDetail[]
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id])

  @@unique([companyId, nomor])
  @@index([tanggal])
  @@index([referensiTipe, referensiId])
  @@index([userId], map: "JurnalEntry_userId_fkey")
}

model JurnalDetail {
  id            Int         @id @default(autoincrement())
  jurnalEntryId Int
  akunId        Int
  debit         Decimal     @default(0.00) @db.Decimal(15, 2)
  kredit        Decimal     @default(0.00) @db.Decimal(15, 2)
  keterangan    String?
  akun          Akun        @relation(fields: [akunId], references: [id])
  jurnalEntry   JurnalEntry @relation(fields: [jurnalEntryId], references: [id], onDelete: Cascade)

  @@index([jurnalEntryId])
  @@index([akunId])
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum TipeAkun {
  ASET
  KEWAJIBAN
  MODAL
  PENDAPATAN
  BEBAN
}

enum SaldoNormal {
  DEBIT
  KREDIT
}
